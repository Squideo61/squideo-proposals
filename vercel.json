{
  "functions": {
    "api/**/*.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/invites", "destination": "/api/users?_kind=invites" },
    { "source": "/api/proposals", "destination": "/api/proposals/_root" },
    { "source": "/api/templates", "destination": "/api/templates/_root" },
    { "source": "/api/crm/:resource/:id/:action/:subaction", "destination": "/api/crm/:resource?_id=:id&_action=:action&_subaction=:subaction" },
    { "source": "/api/crm/:resource/:id/:action", "destination": "/api/crm/:resource?_id=:id&_action=:action" },
    { "source": "/api/crm/:resource/:id", "destination": "/api/crm/:resource?_id=:id" },
    { "source": "/api/quote-requests-admin/:id/:action", "destination": "/api/quote-requests-admin?_id=:id&_action=:action" },
    { "source": "/api/quote-requests-admin/:id", "destination": "/api/quote-requests-admin?_id=:id" },
    { "source": "/extension-auth", "destination": "/api/extension/auth-page" },
    { "source": "/quote", "destination": "/quote.html" }
  ],
  "crons": [
    { "path": "/api/crm/cron/task-reminders", "schedule": "0 9 * * *" },
    { "path": "/api/crm/cron/gmail-watch-renew", "schedule": "0 5 * * *" },
    { "path": "/api/crm/cron/prune-views", "schedule": "0 3 * * 1" }
  ],
  "headers": [
    {
      "source": "/((?!api/|extension-auth|quote).*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self'; frame-src https://www.youtube.com https://player.vimeo.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/quote(.html)?",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self' https://squideo.com https://*.squideo.com https://squideo.co.uk https://*.squideo.co.uk https://*.duda.co https://*.dudaone.com https://*.multiscreensite.com"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" }
      ]
    }
  ]
}
